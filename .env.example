# Copy to .env and fill in. .env is gitignored; this template is committed.

# Required: OpenAI API key (workhorse gpt-4.1-mini + synthesis gpt-5-mini)
OPENAI_API_KEY=sk-...

# Optional: override the local SearXNG endpoint
SEARXNG_URL=http://localhost:8080

# Optional: override default model IDs
MODEL_WORKHORSE=gpt-4.1-mini
MODEL_SYNTH=gpt-5-mini

# Optional: synth reasoning effort (low|medium|high). Default "low" — synth
# only organizes pre-validated facts, so low effort is near-frontier here and
# much faster. Raise to "medium" if briefing quality regresses.
MODEL_SYNTH_EFFORT=low
